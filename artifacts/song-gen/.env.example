# ─── App ────────────────────────────────────────────────────────────────────
APP_ENV=development           # development | production
LOG_LEVEL=INFO

# ─── Generator ──────────────────────────────────────────────────────────────
# Which backend to use by default: "local" or "remote_gpu"
# Per-request `mode` field always overrides this.
GENERATOR_PROVIDER=local

# For production with the GPU worker active:
# GENERATOR_PROVIDER=remote_gpu

# ─── Local Generator ────────────────────────────────────────────────────────
# Path to save generated audio files (relative to project root)
OUTPUT_DIR=generated

# ─── Remote GPU Worker ──────────────────────────────────────────────────────
# URL of the gpu-worker service (see artifacts/gpu-worker/).
#
# Development (both services on the same machine):
REMOTE_WORKER_URL=http://localhost:9000
#
# Production (worker on a separate GPU server):
# REMOTE_WORKER_URL=https://gpu.yourserver.com
#
# Replit deployment calling an external GPU server:
# REMOTE_WORKER_URL=https://gpu.yourserver.com

# Bearer token sent in: Authorization: Bearer <token>
# Must match WORKER_TOKEN set in the gpu-worker's .env.
# Leave blank to disable auth (development only).
REMOTE_WORKER_TOKEN=

# Timeout for all requests to the worker, in seconds.
# Should be higher than the worker's GENERATION_TIMEOUT_SEC.
REMOTE_WORKER_TIMEOUT_SEC=300
