# ─── Worker process ───────────────────────────────────────────────────────────
PORT=9000
LOG_LEVEL=INFO
APP_ENV=development           # development | production

# ─── Auth ─────────────────────────────────────────────────────────────────────
# If set, every request to protected routes must include:
#   Authorization: Bearer <token>
# The main app sends this via REMOTE_WORKER_TOKEN.
# Leave blank to disable auth (development only).
WORKER_TOKEN=

# ─── YuE model ────────────────────────────────────────────────────────────────
# Filesystem path to the YuE checkpoint directory, or a HuggingFace repo id.
#
# HuggingFace Hub (downloads automatically on first load):
#   YUE_MODEL_PATH=m-a-p/YuE-s2-lyric-audiovae-24k-v1.1
#
# Local checkpoint (copy weights to server first):
#   YUE_MODEL_PATH=/models/yue-s2-lyric
#
# Leave blank to run in stub mode (silent WAV, no GPU required).
# Stub mode is used automatically in development / CI.
YUE_MODEL_PATH=

# Compute device. Must be "cuda" on a GPU server.
# Falls back to "cpu" automatically if CUDA is unavailable.
YUE_DEVICE=cuda

# Floating-point precision.
# fp16  — standard for NVIDIA GPU inference (A10, A100, H100, etc.)
# bf16  — better numerical stability, requires Ampere+ GPU
# fp32  — CPU or debugging only (slow, high memory)
YUE_DTYPE=fp16

# Maximum duration the worker will accept per request (hard cap, seconds).
YUE_MAX_DURATION_SEC=300

# Sample rate of the YuE audio output. Must match the checkpoint.
# YuE-s2-lyric checkpoints use 24000 Hz.
YUE_SAMPLE_RATE=24000

# Number of diffusion / sampling steps. Higher = better quality, slower.
YUE_NUM_STEPS=50

# Classifier-free guidance scale. Higher = closer to prompt, less variation.
# Typical range: 1.5–5.0
YUE_CFG_SCALE=3.0

# Generation timeout in seconds.
# Set lower than REMOTE_WORKER_TIMEOUT_SEC in the main app.
GENERATION_TIMEOUT_SEC=240

# ─── Output ────────────────────────────────────────────────────────────────────
# Directory where generated WAV files are saved and served as static files.
OUTPUT_DIR=output

# ─── Model defaults ────────────────────────────────────────────────────────────
# Used when /load-model is called without a model_name body.
DEFAULT_MODEL_NAME=yue-base
